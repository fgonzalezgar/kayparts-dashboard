<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  
  # Redirigir a HTTPS si es necesario (opcional, Hostinger suele tener su propio botón de Forzar HTTPS)
  # RewriteCond %{HTTPS} off
  # RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # Manejar Clean URLs: Si el archivo solicitado no existe, intentar servirlo como .html
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME}.html -f
  RewriteRule ^(.*)$ $1.html [L]

  # Manejar rutas de Next.js (SPA): Si no existe el archivo, servir el index.html principal
  # Esto es útil si usas rutas dinámicas del lado del cliente que no han sido exportadas.
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>
